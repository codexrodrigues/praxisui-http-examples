### status: runtime-confirmed,recommended
### public: false
### authRequired: true
### destructive: false
### requiresTenantHeaders: true

@baseUrl = https://praxis-api-quickstart.onrender.com
@tenantId = demo
@userId = example-user
@envId = public

GET {{baseUrl}}/api/human-resources/cargos/options/by-ids?ids=1,2,3
Accept: application/json
X-Tenant-ID: {{tenantId}}
X-User-ID: {{userId}}
X-Env: {{envId}}
