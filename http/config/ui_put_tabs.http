### status: runtime-confirmed,recommended
### public: false
### authRequired: true
### destructive: false
### requiresTenantHeaders: true

@baseUrl = https://praxis-api-quickstart.onrender.com
@tenantId = demo
@userId = demo-user-1

PUT {{baseUrl}}/api/praxis/config/ui?componentType=praxis-tabs&componentId=tabs:cliente-tabs&scope=user
Content-Type: application/json
Accept: application/json
X-Tenant-ID: {{tenantId}}
X-User-ID: {{userId}}

< ../../payloads/config/ui_put_tabs.json
