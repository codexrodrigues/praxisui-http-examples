### status: runtime-confirmed,recommended
### public: false
### authRequired: true
### destructive: false
### requiresTenantHeaders: true

@baseUrl = https://praxis-api-quickstart.onrender.com
@tenantId = demo
@userId = demo-user-1

GET {{baseUrl}}/api/praxis/config/ui?componentType=praxis-table&componentId=table-config:employees
Accept: application/json
Origin: http://localhost:9999
X-Tenant-ID: {{tenantId}}
X-User-ID: {{userId}}
